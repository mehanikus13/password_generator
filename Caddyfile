# Replace example.com with your domain
example.com {
    root * /srv
    file_server

    header /* Cache-Control "public, max-age=31536000, immutable"

    @assets {
        path *.css *.js
    }

    handle @assets {
        file_server
    }
}

# Local dev fallback
localhost {
    root * /srv
    file_server
}
